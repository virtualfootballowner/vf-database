{
  "name": "vfl-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bot:dev": "tsx src/bot/index.ts",
    "bot:start": "tsx src/bot/index.ts",
    "db:seed:s1": "tsx scripts/seed-s1-stats.ts",
    "db:import:website": "tsx scripts/import-website-matches.ts",
    "db:seed:fixtures": "tsx scripts/seed-fixtures-assets.ts",
    "db:sync:stats": "npm run db:import:website && npm run db:seed:fixtures",
    "db:fill:records": "tsx scripts/fill-team-season-records-from-matches.ts",
    "db:fill:s1-records": "tsx scripts/fill-team-season-records-from-matches.ts 1",
    "db:fill:s2-records": "tsx scripts/fill-team-season-records-from-matches.ts 2",
    "db:fill:s1-squads": "tsx scripts/fill-season-squads-from-events.ts 1",
    "db:fill:s2-squads": "tsx scripts/fill-season-squads-from-events.ts 2",
    "db:award:s1-trophies": "tsx scripts/award-s1-champion-trophies.ts",
    "db:refresh:player-goals-assists": "tsx scripts/refresh-player-goal-assist-totals.ts",
    "db:verify:repo": "tsx scripts/verify-repo-vs-db.ts",
    "db:seed:managers": "tsx scripts/apply-team-manager-seed.ts",
    "db:ensure:manager-rows": "tsx scripts/apply-team-manager-seed.ts --ensure-rows",
    "cron:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
